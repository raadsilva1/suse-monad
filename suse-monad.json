  "commands": {
    "repo_verify": "zypper lr --xmlout | grep -Fq '<alias>{{repo.alias}}</alias>'",
    "repo_add": "zypper -n ar -f -p {{repo.priority}} {{repo.url}} {{repo.alias}}",
    "repo_refresh": "zypper -n ref {{repo.alias}}",
    "refresh": "zypper -n ref",
    "dist_upgrade": "zypper -n dup --allow-vendor-change --download-in-advance",
    "install": "zypper -n in --no-recommends {{package.name}}",
    "remove": "zypper -n rm {{package.name}}",
    "verify": "rpm -q {{package.name}} >/dev/null 2>&1",
    "search": "zypper -n se -x --match-exact {{package.name}} | grep -Fq '<name>{{package.name}}</name>'",
    "service_enable": "sh -c 'if [ \"{{service.scope}}\" = \"user\" ]; then su - {{username}} -c \"systemctl --user enable {{service.name}}.service\"; else systemctl enable {{service.name}}.service; fi'",
    "prepare": [
      "zypper -n ref",
      "sh -c '[ \"{{feature_system_update}}\" = \"true\" ] && zypper -n dup --allow-vendor-change --download-in-advance || true'",
      "sh -c 'zypper -n clean --all || true'"
    ],
    "hooks": {
      "before_all": [
        "mkdir -p /var/lib/suse-monad /var/log /etc/suse-monad",
        "touch /var/log/suse-monad.log"
      ],
      "after_all": [
        "fc-cache -f >/dev/null 2>&1 || true"
      ],
      "before_group": [],
      "after_group": [],
      "before_file_write": [],
      "after_file_write": [],
      "before_service_enable": [],
      "after_service_enable": [],
      "final_success": [
        "su - {{username}} -c 'xmonad --recompile >/dev/null 2>&1 || true'"
      ],
      "recovery": []
    }
  },
  "files": [
    {
      "destination": "{{home_dir}}/.xinitrc",
      "template": "xinitrc",
      "owner": "{{username}}",
      "group": "{{group_name}}",
      "mode": "0755",
      "overwrite": true,
      "backup": true,
      "conditions": ["always"]
    },
    {
      "destination": "{{home_dir}}/.xsession",
      "template": "xsession",
      "owner": "{{username}}",
      "group": "{{group_name}}",
