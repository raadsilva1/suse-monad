{
  "meta": {
    "project_name": "suse-monad",
    "schema_version": "1.0.0",
    "target_distro": "openSUSE Tumbleweed",
    "target_release_channel": "rolling",
    "supported_architectures": ["x86_64"]
  },
  "paths": {
    "config_root": "/etc/suse-monad",
    "log_file": "/var/log/suse-monad.log",
    "state_file": "/var/lib/suse-monad/state.json",
    "backup_root": "/var/lib/suse-monad/backups",
    "xsessions_dir": "/usr/share/xsessions",
    "session_wrapper": "/usr/local/bin/suse-monad-session"
  },
  "ui": {
    "welcome_title": "Welcome to suse-monad",
    "welcome_text": "This installer prepares an xMonad-first desktop on openSUSE Tumbleweed with practical daily-use applications and safe defaults.",
    "x11_honesty_explanation": "Honesty note: xMonad is delivered here as an X11 session. Optional Wayland-friendly applications can be installed, but the desktop session itself is not Wayland-native.",
    "plan_summary": "Plan: profile '{{host_profile}}' for user '{{username}}' on openSUSE Tumbleweed. Terminal '{{chosen_terminal}}', browser '{{chosen_browser}}', editor '{{chosen_editor}}', launcher '{{chosen_launcher}}'.",
    "confirm_prompt": "Proceed with repository checks, package installation, file generation, service enablement, and verification?",
    "final_next_steps": "Log out, choose the 'SUSE Monad' session from your display manager, and log back in. If you do not use a display manager, run 'startx' as the target user.",
    "color": true
  },
  "profiles": [
    {
      "name": "balanced",
      "label": "Balanced daily-driver",
      "description": "A practical xMonad desktop with common GUI utilities, audio tools, networking, screenshots, and optional multimedia extras.",
      "package_groups": [
        "core_xmonad",
        "x11_session_base",
        "fonts",
        "terminal",
        "launcher",
        "compositor",
        "wallpaper",
        "notifications",
        "polkit_agent",
        "settings_tools",
        "audio",
        "network",
        "power",
        "file_manager",
        "archive_tools",
        "browser",
        "editor",
        "media_playback",
        "image_viewer",
        "pdf_reader",
        "screenshot",
        "clipboard",
        "productivity",
        "printing",
        "optional_wayland_friendly_apps",
        "laptop_support",
        "bluetooth",
        "development_tools",
        "multimedia_codecs"
      ],
      "features": {
        "browser": true,
        "bluetooth": true,
        "printing": true,
        "laptop_mode": true,
        "media_tools": true,
        "developer_tools": false,
        "optional_wayland_friendly_apps": true,
        "extra_fonts": true,
        "theme_extras": true,
        "third_party_codecs": false,
        "system_update": false,
        "clipboard_history": false
      },
      "defaults": {
        "terminal_cmd": "alacritty",
        "browser_cmd": "firefox",
        "editor_cmd": "xed",
        "file_manager_cmd": "thunar",
        "launcher_cmd": "rofi -show drun",
        "wallpaper_path": "/usr/share/pixmaps/suse-monad-wallpaper.jpg",
        "mod_mask_hs": "mod4Mask",
        "mod_key_name": "Super"
      }
    }
  ],
  "detection": {
    "minimum_root_free_mb": 4096,
    "detect_laptop_from_battery": true,
    "require_network_route": true,
    "supported_display_manager_files": ["/etc/sysconfig/displaymanager"]
  },
  "preflight": {
    "require_root": true,
    "require_network": true,
    "backup_existing_files": true,
    "refuse_non_tumbleweed": true
  },
  "repositories": [
    {
      "alias": "packman",
      "url": "http://ftp.gwdg.de/pub/linux/misc/packman/suse/openSUSE_Tumbleweed/",
      "auto_refresh": true,
      "priority": 90,
      "gpg_check": true,
      "enabled": true,
      "optional": true,
      "purpose": "Additional multimedia codecs and packages when explicitly enabled by feature policy.",
      "conditions": ["only_if_feature_enabled:third_party_codecs"]
    }
  ],
  "package_groups": {
    "core_xmonad": {
      "packages": ["xmonad", "ghc", "ghc_xmonad_contrib", "xmobar"],
      "conditions": ["always"]
    },
    "x11_session_base": {
      "packages": ["xinit", "dbus_x11", "xdg_utils", "xdg_user_dirs"],
      "conditions": ["always"]
    },
    "fonts": {
      "packages": ["dejavu_fonts", "noto_sans_fonts", "jetbrains_mono_fonts"],
      "conditions": ["always"]
    },
    "terminal": {"packages": ["alacritty"], "conditions": ["always"]},
    "launcher": {"packages": ["rofi"], "conditions": ["always"]},
    "compositor": {"packages": ["picom"], "conditions": ["always"]},
    "wallpaper": {"packages": ["feh"], "conditions": ["always"]},
    "notifications": {"packages": ["dunst"], "conditions": ["always"]},
    "polkit_agent": {"packages": ["polkit_gnome"], "conditions": ["always"]},
    "settings_tools": {"packages": ["lxappearance", "xfce4_settings"], "conditions": ["always"]},
    "audio": {"packages": ["pipewire_tools", "pavucontrol", "playerctl"], "conditions": ["always"]},
    "bluetooth": {"packages": ["blueman", "bluez_auto_enable_devices"], "conditions": ["only_if_feature_enabled:bluetooth"]},
    "network": {"packages": ["networkmanager_applet"], "conditions": ["always"]},
    "power": {"packages": ["xfce4_power_manager"], "conditions": ["always"]},
    "file_manager": {"packages": ["thunar", "thunar_volman", "gvfs"], "conditions": ["always"]},
    "archive_tools": {"packages": ["file_roller", "thunar_plugin_archive"], "conditions": ["always"]},
    "browser": {"packages": ["firefox"], "conditions": ["only_if_feature_enabled:browser"]},
    "editor": {"packages": ["xed"], "conditions": ["always"]},
    "media_playback": {"packages": ["mpv"], "conditions": ["only_if_feature_enabled:media_tools"]},
    "image_viewer": {"packages": ["viewnior"], "conditions": ["always"]},
    "pdf_reader": {"packages": ["atril"], "conditions": ["always"]},
    "screenshot": {"packages": ["flameshot"], "conditions": ["always"]},
    "clipboard": {"packages": ["copyq"], "conditions": ["only_if_feature_enabled:clipboard_history"]},
    "productivity": {"packages": ["libreoffice"], "conditions": ["always"]},
    "optional_wayland_friendly_apps": {"packages": ["wayland_app_launcher"], "conditions": ["only_if_feature_enabled:optional_wayland_friendly_apps"]},
    "laptop_support": {"packages": ["tlp"], "conditions": ["only_if_laptop"]},
    "printing": {"packages": ["cups"], "conditions": ["only_if_feature_enabled:printing"]},
    "development_tools": {"packages": ["git"], "conditions": ["only_if_feature_enabled:developer_tools"]},
    "multimedia_codecs": {"packages": ["packman_codecs"], "conditions": ["only_if_feature_enabled:third_party_codecs"]}
  },
