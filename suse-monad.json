  "templates": {
    "xinitrc": "#!/bin/sh\nexport XDG_SESSION_DESKTOP=suse-monad\nexport DESKTOP_SESSION=suse-monad\nexec /usr/local/bin/suse-monad-session\n",
    "xsession": "#!/bin/sh\nexport XDG_SESSION_DESKTOP=suse-monad\nexport DESKTOP_SESSION=suse-monad\nexec /usr/local/bin/suse-monad-session\n",
    "session_wrapper": "#!/bin/sh\nset -eu\nif [ -f \"$HOME/.config/suse-monad/environment\" ]; then\n  . \"$HOME/.config/suse-monad/environment\"\nfi\nexport XDG_CURRENT_DESKTOP=xmonad\nexport XDG_SESSION_DESKTOP=suse-monad\nexport DESKTOP_SESSION=suse-monad\nexport GTK_USE_PORTAL=0\nexport TERMINAL='{{chosen_terminal}}'\nexport BROWSER='{{chosen_browser}}'\nexport EDITOR='{{chosen_editor}}'\nexport XMONAD_CONFIG_DIR='$HOME/.xmonad'\nmkdir -p \"$HOME/.xmonad\" \"$HOME/.config/suse-monad\"\nif command -v dbus-update-activation-environment >/dev/null 2>&1; then\n  dbus-update-activation-environment --systemd DISPLAY XAUTHORITY XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP DESKTOP_SESSION >/dev/null 2>&1 || true\nfi\nexec xmonad\n",
    "xsessions_desktop": "[Desktop Entry]\nName=SUSE Monad\nComment=xMonad session prepared by suse-monad\nExec=/usr/local/bin/suse-monad-session\nTryExec=/usr/local/bin/suse-monad-session\nType=Application\nDesktopNames=xmonad;suse-monad\n",
    "environment_file": "export TERMINAL='{{chosen_terminal}}'\nexport BROWSER='{{chosen_browser}}'\nexport EDITOR='{{chosen_editor}}'\nexport FILE_MANAGER='{{chosen_file_manager}}'\nexport GTK_THEME='Adwaita'\nexport QT_QPA_PLATFORMTHEME='gtk3'\n",
    "xmonad_hs": "import XMonad\nimport XMonad.Hooks.EwmhDesktops\nimport XMonad.Hooks.ManageDocks\nimport XMonad.Hooks.SetWMName\nimport XMonad.Layout.NoBorders\nimport XMonad.Layout.Spacing\nimport XMonad.Util.EZConfig\nimport XMonad.Util.SpawnOnce\nimport System.Exit\n\nmyTerminal = \"{{chosen_terminal}}\"\nmyBrowser = \"{{chosen_browser}}\"\nmyEditor = \"{{chosen_editor}}\"\nmyFiles = \"{{chosen_file_manager}}\"\nmyLauncher = \"{{chosen_launcher}}\"\nmyLocker = \"{{screen_lock_cmd}}\"\nmyShot = \"{{screenshot_cmd}}\"\nmyModMask = {{mod_mask_hs}}\n\nmyLayout = avoidStruts $ smartBorders $ spacingRaw True (Border 6 6 6 6) True (Border 6 6 6 6) True $ layoutHook def\n\nmyStartupHook = do\n  spawnOnce \"{{home_dir}}/.config/suse-monad/autostart.sh\"\n  setWMName \"LG3D\"\n\nmain :: IO ()\nmain = xmonad $ ewmhFullscreen . ewmh . docks $ def\n  { terminal = myTerminal\n  , modMask = myModMask\n  , borderWidth = 2\n  , normalBorderColor = \"#44475a\"\n  , focusedBorderColor = \"#8be9fd\"\n  , workspaces = [\"1:web\", \"2:term\", \"3:code\", \"4:files\", \"5:chat\", \"6:media\", \"7\", \"8\", \"9\"]\n  , layoutHook = myLayout\n  , startupHook = myStartupHook\n  , manageHook = manageDocks <+> manageHook def\n  } `additionalKeysP`\n  [ (\"M-<Return>\", spawn myTerminal)\n  , (\"M-p\", spawn myLauncher)\n  , (\"M-S-b\", spawn myBrowser)\n  , (\"M-S-e\", spawn myEditor)\n  , (\"M-S-f\", spawn myFiles)\n  , (\"M-S-l\", spawn myLocker)\n  , (\"M-S-s\", spawn myShot)\n  , (\"M-C-r\", spawn \"xmonad --recompile && xmonad --restart\")\n  , (\"M-S-q\", io exitSuccess)\n  ]\n",
    "xmobar_rc": "Config { font = \"xft:DejaVu Sans Mono:size=10\"\n       , additionalFonts = []\n       , bgColor = \"#1e1e2e\"\n       , fgColor = \"#cdd6f4\"\n       , position = Top\n       , lowerOnStart = True\n       , hideOnStart = False\n       , allDesktops = True\n       , persistent = True\n       , commands = [ Run Cpu [\"-t\", \"Cpu: <total>%\", \"-L\", \"20\", \"-H\", \"80\"] 20\n                    , Run Memory [\"-t\", \"Mem: <usedratio>%\"] 20\n                    , Run Date \"%a %F %H:%M\" \"date\" 10\n                    ]\n       , sepChar = \"%\"\n       , alignSep = \"}{\"\n       , template = \"  {{host_profile}}  }{ %cpu% | %memory% | %date%  \"\n       }\n",
    "autostart_sh": "#!/bin/sh\nset -eu\nmkdir -p \"{{home_dir}}/.cache\" \"{{home_dir}}/.config\"\nif command -v xsetroot >/dev/null 2>&1; then xsetroot -cursor_name left_ptr || true; fi\nif command -v feh >/dev/null 2>&1 && [ -e \"{{wallpaper_path}}\" ]; then\n  feh --bg-fill \"{{wallpaper_path}}\" >/dev/null 2>&1 || true\nfi\nif command -v xmobar >/dev/null 2>&1 && [ -f \"{{home_dir}}/.config/xmobar/xmobarrc\" ]; then\n  pgrep -u \"{{username}}\" -x xmobar >/dev/null 2>&1 || xmobar \"{{home_dir}}/.config/xmobar/xmobarrc\" >/dev/null 2>&1 &\nfi\nif command -v dunst >/dev/null 2>&1; then\n  pgrep -u \"{{username}}\" -x dunst >/dev/null 2>&1 || dunst >/dev/null 2>&1 &\nfi\nif command -v picom >/dev/null 2>&1; then\n  pgrep -u \"{{username}}\" -x picom >/dev/null 2>&1 || picom --config \"{{home_dir}}/.config/picom/picom.conf\" >/dev/null 2>&1 &\nfi\nif command -v nm-applet >/dev/null 2>&1; then\n  pgrep -u \"{{username}}\" -x nm-applet >/dev/null 2>&1 || nm-applet >/dev/null 2>&1 &\nfi\nif [ \"{{feature_bluetooth}}\" = \"true\" ] && command -v blueman-applet >/dev/null 2>&1; then\n  pgrep -u \"{{username}}\" -x blueman-applet >/dev/null 2>&1 || blueman-applet >/dev/null 2>&1 &\nfi\nif command -v xfsettingsd >/dev/null 2>&1; then\n  pgrep -u \"{{username}}\" -x xfsettingsd >/dev/null 2>&1 || xfsettingsd >/dev/null 2>&1 &\nfi\nif command -v xfce4-power-manager >/dev/null 2>&1; then\n  pgrep -u \"{{username}}\" -x xfce4-power-manager >/dev/null 2>&1 || xfce4-power-manager >/dev/null 2>&1 &\nfi\nif [ -x /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 ]; then\n  pgrep -u \"{{username}}\" -f polkit-gnome-authentication-agent-1 >/dev/null 2>&1 || /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 >/dev/null 2>&1 &\nfi\n",
    "picom_conf": "backend = \"glx\";\nvsync = true;\nshadow = true;\nshadow-radius = 10;\nshadow-opacity = 0.35;\ncorner-radius = 8;\nfading = true;\nfade-delta = 4;\ninactive-opacity = 1.0;\nactive-opacity = 1.0;\nuse-damage = true;\n",
    "dunst_rc": "[global]\nmonitor = 0\nfollow = mouse\nwidth = 360\nheight = 120\noffset = 20x40\norigin = top-right\ntransparency = 10\nframe_color = \"#8be9fd\"\nseparator_color = frame\nfont = DejaVu Sans 10\nmarkup = full\nformat = \"<b>%s</b>\\n%b\"\n[urgency_low]\nbackground = \"#1e1e2e\"\nforeground = \"#cdd6f4\"\ntimeout = 5\n[urgency_normal]\nbackground = \"#1e1e2e\"\nforeground = \"#cdd6f4\"\ntimeout = 8\n[urgency_critical]\nbackground = \"#3b0f1e\"\nforeground = \"#ffffff\"\nframe_color = \"#ff5555\"\ntimeout = 0\n"
  },
  "xmonad": {
    "mod_mask_hs": "mod4Mask",
    "mod_key_name": "Super",
    "status_bar_launch": "xmobar ~/.config/xmobar/xmobarrc",
    "screen_lock_cmd": "loginctl lock-session",
    "screenshot_cmd": "flameshot gui",
    "network_applet_cmd": "nm-applet",
    "bluetooth_applet_cmd": "blueman-applet",
    "notifications_cmd": "dunst",
    "compositor_cmd": "picom --config ~/.config/picom/picom.conf",
    "wallpaper_cmd": "feh --bg-fill {{wallpaper_path}}",
    "audio_control_cmd": "pavucontrol"
  },
  "session": {
    "xsessions_dir": "/usr/share/xsessions",
    "wrapper_path": "/usr/local/bin/suse-monad-session",
    "register_xsession": true,
    "install_xinitrc": true,
    "autologin": false,
    "environment": {
      "XDG_CURRENT_DESKTOP": "xmonad",
      "XDG_SESSION_DESKTOP": "suse-monad",
      "DESKTOP_SESSION": "suse-monad"
    }
  },
  "services": [
    {"name": "NetworkManager", "scope": "system", "enabled": true, "required": false, "conditions": ["always"]},
    {"name": "bluetooth", "scope": "system", "enabled": true, "required": false, "conditions": ["only_if_feature_enabled:bluetooth"]},
    {"name": "cups", "scope": "system", "enabled": true, "required": false, "conditions": ["only_if_feature_enabled:printing"]},
    {"name": "tlp", "scope": "system", "enabled": true, "required": false, "conditions": ["only_if_laptop"]}
  ],
  "users": {
    "prefer_sudo_user": true,
    "allow_prompt": false,
    "min_uid": 1000
  },
  "permissions": {
    "default_owner": "{{username}}",
    "default_group": "{{group_name}}",
    "default_file_mode": "0644",
    "default_dir_mode": "0755"
  },
  "backups": {
    "enabled": true,
    "directory": "/var/lib/suse-monad/backups",
    "max_copies": 10
  },
  "rollback": {
    "restore_files_on_failure": false,
    "remove_failed_temp_files": true
  },
  "verification": [
    {
      "type": "command_exists",
      "description": "xmonad command is present",
      "command": "xmonad",
      "required": true,
      "conditions": ["always"]
    },
    {
      "type": "file_exists",
      "description": "User xMonad configuration exists",
      "path": "{{home_dir}}/.xmonad/xmonad.hs",
      "required": true,
      "conditions": ["always"]
    },
    {
      "type": "file_contains",
      "description": "xMonad config contains selected terminal",
      "path": "{{home_dir}}/.xmonad/xmonad.hs",
      "token": "myTerminal = \"{{chosen_terminal}}\"",
      "required": true,
      "conditions": ["always"]
    },
    {
      "type": "file_exists",
      "description": "X session desktop entry exists",
      "path": "/usr/share/xsessions/suse-monad.desktop",
      "required": true,
      "conditions": ["always"]
    },
    {
      "type": "ownership",
      "description": "User xMonad directory belongs to target user",
      "path": "{{home_dir}}/.xmonad/xmonad.hs",
      "required": true,
      "conditions": ["always"]
    },
    {
      "type": "command_success",
      "description": "xMonad can attempt recompilation",
      "command": "su - {{username}} -c 'xmonad --recompile >/dev/null 2>&1 || true'",
      "required": false,
      "conditions": ["always"]
    },
    {
      "type": "service_enabled",
      "description": "NetworkManager is enabled",
      "service": "NetworkManager",
      "required": false,
      "conditions": ["always"]
    }
  ],
  "recovery": {
    "general_hint": "Inspect /var/log/suse-monad.log, review the backup directory under /var/lib/suse-monad/backups, and rerun with --dry-run --verbose to inspect the plan before retrying."
  },
  "logging": {
    "file": "/var/log/suse-monad.log",
    "verbosity": "info",
    "timestamps": true
  },
  "defaults": {
    "profile": "balanced",
    "terminal_cmd": "alacritty",
    "browser_cmd": "firefox",
    "editor_cmd": "xed",
    "file_manager_cmd": "thunar",
    "launcher_cmd": "rofi -show drun",
    "wallpaper_path": "/usr/share/pixmaps/suse-monad-wallpaper.jpg",
    "execution": {
      "interactive": true,
      "dry_run": false,
      "continue_on_nonfatal": true,
      "strict_mode": false,
      "logging_verbosity": "info",
      "command_timeout_seconds": 900,
      "retry_count": 1
    }
  },
  "conditionals": {
    "known": [
      "only_if_laptop",
      "only_if_desktop",
      "only_if_feature_enabled:<name>",
      "only_if_file_missing:<path>",
      "only_if_command_exists:<cmd>",
      "only_if_package_exists:<pkg>",
      "only_if_repo_enabled:<alias>",
      "only_if_service_present:<name>",
      "only_if_user_selected"
    ]
  },
  "features": {
    "browser": {"enabled": true, "label": "Install a browser"},
    "bluetooth": {"enabled": true, "label": "Install Bluetooth support"},
    "printing": {"enabled": true, "label": "Install printing stack"},
    "laptop_mode": {"enabled": true, "label": "Allow laptop-specific additions"},
    "media_tools": {"enabled": true, "label": "Install multimedia player and helpers"},
    "developer_tools": {"enabled": false, "label": "Install development basics"},
    "optional_wayland_friendly_apps": {"enabled": true, "label": "Install extra Wayland-friendly applications without changing the X11 session"},
    "extra_fonts": {"enabled": true, "label": "Install extra fonts"},
    "theme_extras": {"enabled": true, "label": "Install appearance helpers"},
    "third_party_codecs": {"enabled": false, "label": "Enable Packman and extra codecs"},
    "system_update": {"enabled": false, "label": "Run a full zypper dup before desktop provisioning"},
    "clipboard_history": {"enabled": false, "label": "Install clipboard history tool"}
  }
}
